generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_HOST")
}

// Enums para o model Grupo
enum CategoriaGrupo {
  HOMENS
  UNVT
  MULHERES
  MISTO
  NEW
  CASAIS
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

// Enums para o model Chamado
enum ChamadoStatus {
  PENDENTE
  RECEBIDO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum ChamadoPrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum TipoCampoMinisterio {
  TEXTO
  TEXTAREA
  SELECT
  MULTISELECT
  ANEXO
}

// Enums para o model Form
enum FormStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum FormVisibility {
  PUBLIC
  PRIVATE
}

enum FieldType {
  SHORT_TEXT
  LONG_TEXT
  EMAIL
  NUMBER
  PHONE
  RADIO
  CHECKBOX
  SELECT
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relação com usuários
  users users[]
}

model Campus {
  id        String   @id @default(cuid())
  nome      String
  cidade    String
  estado    String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  users       users[]
  visitantes  visitantes[]
  grupos      grupo[]
  forms       Form[]
  etiquetas   Etiqueta[]
  ministerios Ministerio[]
  chamados    Chamado[]

  @@unique([cidade, estado])
}

model bairros {
  id        String   @id @default(cuid())
  nome      String
  cidadeId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação com grupos
  grupos grupo[]
}

model visitantes {
  id                    String   @id @default(cuid())
  estado                String?
  cidade                String?
  bairro                String?
  created_at            DateTime @default(now())
  como_chegou_ate_nos   String?
  como_nos_conheceu     String?
  culto                 String
  estado_civil          String
  frequenta_igreja      String?
  genero                String
  idade                 Int
  interesse_em_conhecer Json
  nome                  String
  observacao            String?
  qual_igreja           String?
  telefone              String
  responsavel_nome      String?
  responsavel_telefone  String?
  mensagem_enviada      Boolean  @default(false)

  // Relação com User
  registeredById String?
  registeredBy   users?  @relation(fields: [registeredById], references: [id])

  // Relação com Campus
  campusId String?
  campus   Campus? @relation(fields: [campusId], references: [id])

  // Relação com Etiquetas
  etiquetas Etiqueta[]
}

model Etiqueta {
  id        String   @id @default(cuid())
  nome      String
  cor       String
  campusId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  campus     Campus       @relation(fields: [campusId], references: [id], onDelete: Cascade)
  visitantes visitantes[]

  @@unique([campusId, nome])
}

model users {
  id                    String   @id @default(cuid())
  email                 String   @unique
  password              String
  name                  String
  phone                 String?
  role                  String   @default("user") // Campo legado - será removido após migração
  roleId                String?
  campusId              String?
  requirePasswordChange Boolean  @default(true)
  approved              Boolean  @default(true)
  dataMembresia         String?
  profileImageUrl       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relação com Role
  roleRelation Role? @relation(fields: [roleId], references: [id])

  // Relação com Campus
  campus Campus? @relation(fields: [campusId], references: [id])

  // Relação com Visitantes
  registeredVisitors visitantes[]

  // Relação com grupos liderados
  gruposLiderados grupo[]

  // Relação com ministérios
  ministeriosLiderados   Ministerio[] @relation("MinisterioLider")
  ministeriosCoLiderados Ministerio[] @relation("MinisterioCoLider")
  ministerios            UserMinisterio[]

  // Relação com empresas
  empresas UserEmpresa[]

  // Relação com formulários
  formsCreated  Form[]
  formResponses FormResponse[] @relation("FormResponses")

  // Relação com chamados
  chamadosAbertos    Chamado[]          @relation("ChamadosAbertos")
  comentariosChamado ChamadoComentario[]
}

model grupo {
  id        String         @id @default(cuid())
  nome      String
  categoria CategoriaGrupo
  diaSemana DiaSemana
  horario   String
  bairroId  String?
  campusId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relações
  bairro  bairros? @relation(fields: [bairroId], references: [id])
  campus  Campus?  @relation(fields: [campusId], references: [id])
  lideres users[]
}

model Empresa {
  id              String   @id @default(cuid())
  nomeNegocio     String
  ramoAtuacao     String
  detalhesServico String   @db.Text
  whatsapp        String
  endereco        String?
  site            String?
  instagram       String?
  facebook        String?
  linkedin        String?
  email           String
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relação com usuários (muitos para muitos)
  usuarios UserEmpresa[]
}

model UserEmpresa {
  id        String   @id @default(cuid())
  userId    String
  empresaId String
  createdAt DateTime @default(now())

  // Relações
  user    users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([userId, empresaId])
}

// Models para Sistema de Formulários Dinâmicos
model Form {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  status       FormStatus     @default(DRAFT)
  visibility   FormVisibility @default(PUBLIC)
  publicToken  String?        @unique
  privateToken String?        @unique
  requireAuth  Boolean        @default(false)
  emailEnabled Boolean        @default(false)
  emailSubject String?
  emailBody    String?        @db.Text
  expiresAt    DateTime?
  campusId     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdById  String

  // Relações
  createdBy users          @relation(fields: [createdById], references: [id])
  campus    Campus?        @relation(fields: [campusId], references: [id])
  fields    FormField[]
  responses FormResponse[]
}

model FormField {
  id          String    @id @default(cuid())
  formId      String
  label       String
  type        FieldType
  required    Boolean   @default(false)
  placeholder String?   @db.Text
  helpText    String?   @db.Text
  options     Json?
  order       Int

  // Relações
  form    Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers FormAnswer[]
}

model FormResponse {
  id               String   @id @default(cuid())
  formId           String
  respondentEmail  String?
  respondentUserId String?
  submittedAt      DateTime @default(now())

  // Relações
  form           Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  respondentUser users?       @relation("FormResponses", fields: [respondentUserId], references: [id])
  answers        FormAnswer[]
}

model FormAnswer {
  id         String @id @default(cuid())
  responseId String
  fieldId    String
  value      String @db.Text

  // Relações
  response FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  field    FormField    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Ministerio {
  id        String   @id @default(cuid())
  nome      String
  descricao String?  @db.Text
  campusId  String?
  liderId   String
  coLiderId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  campus    Campus?              @relation(fields: [campusId], references: [id])
  lider     users                @relation("MinisterioLider", fields: [liderId], references: [id])
  coLider   users?               @relation("MinisterioCoLider", fields: [coLiderId], references: [id])
  membros   UserMinisterio[]
  chamados  Chamado[]
  campos    CampoMinisterio[]
  navConfig MinisterioNavConfig?
}

model MinisterioNavConfig {
  id                 String     @id @default(cuid())
  ministerioId       String     @unique
  ministerio         Ministerio @relation(fields: [ministerioId], references: [id], onDelete: Cascade)
  paginaInicial      String     @default("/register")
  paginasHabilitadas Json       @default("[]")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model UserMinisterio {
  id          String   @id @default(cuid())
  userId      String
  ministerioId String
  createdAt   DateTime @default(now())

  // Relações
  user       users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ministerio Ministerio @relation(fields: [ministerioId], references: [id], onDelete: Cascade)

  @@unique([userId, ministerioId])
}

// ─── Sistema de Chamados ───────────────────────────────────────────────────────

model Chamado {
  id           String            @id @default(cuid())
  codigo       String            @unique
  titulo       String
  descricao    String?           @db.Text
  status       ChamadoStatus     @default(PENDENTE)
  prioridade   ChamadoPrioridade @default(MEDIA)
  ministerioId String
  abertoPorId  String
  campusId     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  ministerio  Ministerio          @relation(fields: [ministerioId], references: [id])
  abertoPor   users               @relation("ChamadosAbertos", fields: [abertoPorId], references: [id])
  campus      Campus?             @relation(fields: [campusId], references: [id])
  respostas   ChamadoResposta[]
  comentarios ChamadoComentario[]
}

model CampoMinisterio {
  id           String              @id @default(cuid())
  ministerioId String
  label        String
  tipo         TipoCampoMinisterio
  opcoes       Json?
  obrigatorio  Boolean             @default(false)
  ordem        Int                 @default(0)
  createdAt    DateTime            @default(now())

  ministerio Ministerio        @relation(fields: [ministerioId], references: [id], onDelete: Cascade)
  respostas  ChamadoResposta[]
}

model ChamadoResposta {
  id        String   @id @default(cuid())
  chamadoId String
  campoId   String
  valor     String   @db.Text

  chamado Chamado         @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  campo   CampoMinisterio @relation(fields: [campoId], references: [id])

  @@unique([chamadoId, campoId])
}

model ChamadoComentario {
  id        String   @id @default(cuid())
  chamadoId String
  autorId   String
  texto     String   @db.Text
  createdAt DateTime @default(now())

  chamado Chamado @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  autor   users   @relation(fields: [autorId], references: [id])
}
